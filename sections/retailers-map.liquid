{%- comment -%}
  Retailers Map Section - Displays a Mapbox map with retailer locations
  Requires: retailers-data section to be loaded first
{%- endcomment -%}

{{ 'retailers-map.css' | asset_url | stylesheet_tag }}

<link href="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.css" rel="stylesheet">
<script src="https://api.mapbox.com/mapbox-gl-js/v3.3.0/mapbox-gl.js"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="retailers-page-layout">
  <div class="retailers-map-left">
    <div class="retailers-map-top-bar">&nbsp;</div>
    <div class="retailers-map-wrapper">
      <div class="retailers-map-section section-{{ section.id }}-padding">
        <div class="page-width">
          {% if section.settings.title != blank %}
            <h2 class="retailers-map__title h2{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
              {{ section.settings.title }}
            </h2>
          {% endif %}
        </div>

        <div class="retailers-map__container{% if section.settings.full_width %} retailers-map__container--full-width{% else %} page-width{% endif %}">
          <div id="retailers-map"
               class="retailers-map"
               data-mapbox-token="{{ section.settings.mapbox_token }}"
               data-map-style="{{ section.settings.map_style }}"
               data-initial-zoom="{{ section.settings.initial_zoom }}"
               data-marker-color="{{ section.settings.marker_color }}"
               data-marker-svg="{{ 'marker-pin.svg' | asset_url }}">
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="retailers-map__spacer">
    <div class="retailers-list" id="retailers-country-list">
      <!-- Populated by JavaScript -->
    </div>
  </div>
</div>

<script src="{{ 'retailers-map.js' | asset_url }}" defer></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const retailers = window.retailersData || [];
    const container = document.getElementById('retailers-country-list');

    if (!retailers.length || !container) return;

    const grouped = retailers.reduce((acc, r) => {
      const country = (r.country || 'Other').toLowerCase();
      if (!acc[country]) acc[country] = [];
      acc[country].push(r);
      return acc;
    }, {});

    const sortedCountries = Object.keys(grouped).sort();

    let html = '';
    sortedCountries.forEach(country => {
      const shops = grouped[country].sort((a, b) => a.shop.localeCompare(b.shop));

      html += `
        <details class="retailers-country">
          <summary class="retailers-country__title">${country}</summary>
          <ul class="retailers-country__list">
            ${shops.map(shop => `
              <li class="retailers-country__shop">
                <a href="${shop.url || '#'}" target="_blank" rel="noopener" class="retailers-shop__link">
                  <span class="retailers-shop__name">${shop.shop}</span>
                </a>
                <span class="retailers-shop__address">${shop.address}, ${shop.zip} ${shop.city}</span>
              </li>
            `).join('')}
          </ul>
        </details>
      `;
    });

    container.innerHTML = html;
  });

  // Detach fixed map panel when layout bottom passes viewport bottom, letting footer show
  const layout = document.querySelector('.retailers-page-layout');
  const mapLeft = document.querySelector('.retailers-map-left');

  if (layout && mapLeft) {
    function updateMapPosition() {
      const layoutBottom = layout.getBoundingClientRect().bottom;
      if (layoutBottom <= window.innerHeight) {
        if (!mapLeft.classList.contains('is-at-bottom')) {
          mapLeft.style.top = (window.scrollY - layout.offsetTop) + 'px';
          mapLeft.classList.add('is-at-bottom');
        }
      } else {
        if (mapLeft.classList.contains('is-at-bottom')) {
          mapLeft.classList.remove('is-at-bottom');
          mapLeft.style.top = '';
        }
      }
    }
    window.addEventListener('scroll', updateMapPosition, { passive: true });
  }
</script>

{% schema %}
{
  "name": "Retailers Map",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Find a Retailer"
    },
    {
      "type": "text",
      "id": "mapbox_token",
      "label": "Mapbox Access Token",
      "info": "Get your token from mapbox.com/account/access-tokens"
    },
    {
      "type": "select",
      "id": "map_style",
      "label": "Map Style",
      "options": [
        { "value": "mapbox://styles/mapbox/streets-v12", "label": "Streets" },
        { "value": "mapbox://styles/mapbox/light-v11", "label": "Light" },
        { "value": "mapbox://styles/mapbox/dark-v11", "label": "Dark" },
        { "value": "mapbox://styles/mapbox/outdoors-v12", "label": "Outdoors" },
        { "value": "mapbox://styles/mapbox/satellite-streets-v12", "label": "Satellite" }
      ],
      "default": "mapbox://styles/mapbox/light-v11"
    },
    {
      "type": "range",
      "id": "initial_zoom",
      "label": "Initial Zoom Level",
      "min": 1,
      "max": 18,
      "step": 1,
      "default": 6
    },
    {
      "type": "color",
      "id": "marker_color",
      "label": "Marker Color",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full Width Map",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_list",
      "label": "Show Retailer List Below Map",
      "default": true
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Retailers Map"
    }
  ]
}
{% endschema %}

{%- style -%}
  .shop-finder {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .shop-finder__heading {
    margin-bottom: 3rem;
  }

  .shop-finder__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media screen and (min-width: 750px) {
    .shop-finder__list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .shop-finder__list {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .shop-finder__item {
    padding: 2rem;
    background-color: rgb(var(--color-background));
    border: 1px solid rgba(var(--color-foreground), 0.1);
  }

  .shop-finder__shop-name {
    font-size: 1.4rem;
    font-weight: var(--font-body-weight-bold);
    margin-bottom: 1rem;
    color: var(--seasonal-color);
    text-transform: lowercase;
  }

  .shop-finder__shop-name a {
    color: inherit;
    text-decoration: none;
  }

  .shop-finder__shop-name a:hover {
    text-decoration: underline;
  }

  .shop-finder__address {
    font-size: 1.2rem;
    line-height: 1.6;
  }

  .shop-finder__map-link {
    display: inline-block;
    margin-top: 1rem;
    color: var(--seasonal-color);
    text-decoration: underline;
  }

  .shop-finder__map-link:hover {
    text-decoration: none;
  }
{%- endstyle -%}

<div class="shop-finder page-width section-{{ section.id }}-padding">
  {%- if section.settings.heading != blank -%}
    <h2 class="shop-finder__heading {{ section.settings.heading_size }}">
      {{ section.settings.heading }}
    </h2>
  {%- endif -%}

  <div class="shop-finder__list" id="shop-finder-list-{{ section.id }}"></div>
</div>

<script>
  (function() {
    const container = document.getElementById('shop-finder-list-{{ section.id }}');
    
    // Wait for retailersData to be available
    const renderRetailers = () => {
      if (!window.retailersData || !container) return;
      
      window.retailersData.forEach(retailer => {
        const item = document.createElement('div');
        item.className = 'shop-finder__item';
        item.dataset.lat = retailer.lat || '';
        item.dataset.long = retailer.long || '';
        item.dataset.country = retailer.country || '';
        item.dataset.city = retailer.city || '';
        
        let html = '';
        
        if (retailer.shop) {
          html += '<h3 class="shop-finder__shop-name">';
          if (retailer.url) {
            html += `<a href="${retailer.url}" target="_blank" rel="noopener noreferrer">${retailer.shop}</a>`;
          } else {
            html += retailer.shop;
          }
          html += '</h3>';
        }
        
        html += '<div class="shop-finder__address">';
        if (retailer.address) {
          html += `<p>${retailer.address}</p>`;
        }
        if (retailer.zip || retailer.city) {
          html += `<p>${retailer.zip || ''}${retailer.zip && retailer.city ? ' ' : ''}${retailer.city || ''}</p>`;
        }
        if (retailer.country) {
          html += `<p>${retailer.country}</p>`;
        }
        html += '</div>';
        
        if (retailer.lat && retailer.long) {
          html += `<a href="https://www.google.com/maps?q=${retailer.lat},${retailer.long}" target="_blank" rel="noopener noreferrer" class="shop-finder__map-link">View on map</a>`;
        }
        
        item.innerHTML = html;
        container.appendChild(item);
      });
      
      // Dispatch event for custom functionality
      document.dispatchEvent(new CustomEvent('retailersRendered', { detail: window.retailersData }));
    };
    
    // Check if data is already available, otherwise wait
    if (window.retailersData) {
      renderRetailers();
    } else {
      document.addEventListener('DOMContentLoaded', renderRetailers);
    }
  })();
</script>

{% schema %}
{
  "name": "Shop Finder",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find a Store"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "paragraph",
      "content": "Retailer data is managed in the 'Retailers Data' section (add it to your header group)"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Shop Finder"
    }
  ]
}
{% endschema %}
}
{% endschema %}

{%- style -%}
  .shop-finder {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .shop-finder__heading {
    margin-bottom: 3rem;
  }

  .shop-finder__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media screen and (min-width: 750px) {
    .shop-finder__list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .shop-finder__list {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .shop-finder__item {
    padding: 2rem;
    background-color: rgb(var(--color-background));
    border: 1px solid rgba(var(--color-foreground), 0.1);
  }

  .shop-finder__shop-name {
    font-size: 1.4rem;
    font-weight: var(--font-body-weight-bold);
    margin-bottom: 1rem;
    color: var(--seasonal-color);
    text-transform: lowercase;
  }

  .shop-finder__shop-name a {
    color: inherit;
    text-decoration: none;
  }

  .shop-finder__shop-name a:hover {
    text-decoration: underline;
  }

  .shop-finder__address {
    font-size: 1.2rem;
    line-height: 1.6;
  }

  .shop-finder__map-link {
    display: inline-block;
    margin-top: 1rem;
    color: var(--seasonal-color);
    text-decoration: underline;
  }

  .shop-finder__map-link:hover {
    text-decoration: none;
  }
{%- endstyle -%}

<div class="shop-finder page-width section-{{ section.id }}-padding">
  {%- if section.settings.heading != blank -%}
    <h2 class="shop-finder__heading {{ section.settings.heading_size }}">
      {{ section.settings.heading }}
    </h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="shop-finder__list">
      {%- for block in section.blocks -%}
        <div class="shop-finder__item" {{ block.shopify_attributes }}>
          {%- if block.settings.shop != blank -%}
            <h3 class="shop-finder__shop-name">
              {%- if block.settings.url != blank -%}
                <a href="{{ block.settings.url }}" target="_blank" rel="noopener noreferrer">{{ block.settings.shop }}</a>
              {%- else -%}
                {{ block.settings.shop }}
              {%- endif -%}
            </h3>
          {%- endif -%}
          
          <div class="shop-finder__address">
            {%- if block.settings.address != blank -%}
              <p>{{ block.settings.address }}</p>
            {%- endif -%}
            {%- if block.settings.zip != blank or block.settings.city != blank -%}
              <p>{{ block.settings.zip }}{% if block.settings.zip != blank and block.settings.city != blank %} {% endif %}{{ block.settings.city }}</p>
            {%- endif -%}
            {%- if block.settings.country != blank -%}
              <p>{{ block.settings.country }}</p>
            {%- endif -%}
          </div>

          {%- if block.settings.lat != blank and block.settings.long != blank -%}
            <a 
              href="https://www.google.com/maps?q={{ block.settings.lat }},{{ block.settings.long }}" 
              target="_blank" 
              rel="noopener noreferrer"
              class="shop-finder__map-link"
            >
              View on map
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Shop Finder",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find a Store"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "shop",
      "name": "Shop",
      "settings": [
        {
          "type": "text",
          "id": "shop",
          "label": "Shop name"
        },
        {
          "type": "text",
          "id": "address",
          "label": "Address"
        },
        {
          "type": "text",
          "id": "zip",
          "label": "ZIP / Postal code"
        },
        {
          "type": "text",
          "id": "city",
          "label": "City"
        },
        {
          "type": "text",
          "id": "country",
          "label": "Country"
        },
        {
          "type": "text",
          "id": "lat",
          "label": "Latitude"
        },
        {
          "type": "text",
          "id": "long",
          "label": "Longitude"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Website URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop Finder",
      "blocks": [
        {
          "type": "shop"
        }
      ]
    }
  ]
}
{% endschema %}

{%- comment -%}
  This section reads retailer data from section blocks or metaobjects.
  The data is available via window.retailersData for map and custom functionality.
  
  Option 1: Use section blocks (configured in theme customizer)
  Option 2: Use metaobjects (go to Settings > Custom data > Metaobjects)
{%- endcomment -%}

<script>
  window.retailersData = [
    {%- comment -%} First try section blocks {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'retailer' -%}
          {
            "id": "{{ block.id }}",
            "shop": {{ block.settings.shop | json }},
            "address": {{ block.settings.address | json }},
            "zip": {{ block.settings.zip | json }},
            "city": {{ block.settings.city | json }},
            "country": {{ block.settings.country | json }},
            "lat": {{ block.settings.lat | json }},
            "long": {{ block.settings.long | json }},
            "url": {{ block.settings.url | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}
      {%- comment -%} Fallback to metaobjects {%- endcomment -%}
      {%- assign retailers = shop.metaobjects.retailer.values -%}
      {%- for retailer in retailers -%}
        {
          "id": "{{ retailer.id }}",
          "shop": {{ retailer.shop | json }},
          "address": {{ retailer.address | json }},
          "zip": {{ retailer.zip | json }},
          "city": {{ retailer.city | json }},
          "country": {{ retailer.country | json }},
          "lat": {{ retailer.lat | json }},
          "long": {{ retailer.long | json }},
          "url": {{ retailer.url | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    {%- endif -%}
  ];
</script>

{% schema %}
{
  "name": "Retailers Data",
  "tag": "div",
  "class": "retailers-data-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Add retailers below or use Content > Metaobjects > Retailer"
    }
  ],
  "blocks": [
    {
      "type": "retailer",
      "name": "Retailer",
      "settings": [
        {
          "type": "text",
          "id": "shop",
          "label": "Shop Name"
        },
        {
          "type": "text",
          "id": "address",
          "label": "Street Address"
        },
        {
          "type": "text",
          "id": "zip",
          "label": "Postal Code"
        },
        {
          "type": "text",
          "id": "city",
          "label": "City"
        },
        {
          "type": "text",
          "id": "country",
          "label": "Country"
        },
        {
          "type": "text",
          "id": "lat",
          "label": "Latitude",
          "info": "e.g. 50.9767902"
        },
        {
          "type": "text",
          "id": "long",
          "label": "Longitude",
          "info": "e.g. 4.6359949"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Website URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Retailers Data"
    }
  ]
}
{% endschema %}

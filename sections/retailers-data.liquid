{%- comment -%}
  This section reads retailer data from metaobjects.
  The data is available via window.retailersData for custom functionality.
  
  Setup:
  1. Go to Settings > Custom data > Metaobjects > Add definition
  2. Create "Retailer" with fields: shop, address, zip, city, country, lat, long, url
  3. Enable "Storefront access" for web
  4. Add retailers in Content > Metaobjects > Retailer
{%- endcomment -%}

<script>
  window.retailersData = [
    {%- assign retailers = shop.metaobjects.retailer.values -%}
    {%- for retailer in retailers -%}
      {
        "id": "{{ retailer.id }}",
        "shop": {{ retailer.shop | json }},
        "address": {{ retailer.address | json }},
        "zip": {{ retailer.zip | json }},
        "city": {{ retailer.city | json }},
        "country": {{ retailer.country | json }},
        "lat": {{ retailer.lat | json }},
        "long": {{ retailer.long | json }},
        "url": {{ retailer.url | json }}
      }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];
</script>

{% schema %}
{
  "name": "Retailers Data",
  "tag": "div",
  "class": "retailers-data-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Retailers are managed in Content > Metaobjects > Retailer"
    }
  ],
  "presets": [
    {
      "name": "Retailers Data"
    }
  ]
}
{% endschema %}
